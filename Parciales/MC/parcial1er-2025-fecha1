// Resolver con SEMÁFOROS el siguiente problema. Se tiene un vectar A de 1.000.000 de números, del cual se debe obtener el 
// promedio de sus valores utilizando 10 procesos Worker. Al terminar todos los procesos deben imprimir el resultado.
// Nota: maximizar concurrencia; unicamente se pueden usar los 10 procesos Worker.

int vector[1000000];
int cantDivididos = 1000000 / 10; // cantidad de numeros que debe procesar cada Worker
int suma = 0, cant = 0; // variable global para acumular la suma de los numeros y para la barrera
sem mutex = 1; // semáforo para proteger la variable global suma
sem barrera = 1; // semáforo para que 1 worker a la vez pueda actualizar la variable global cant para la barrera
sem espero = 0; // semáforo para esperar a que todos los Workers terminen

Process Worker[id: 0..9]{
    int i;
    int ini = id * cantDivididos; // índice inicial para cada Worker
    int fin = cantDivididos + ini - 1; // índice final para cada Worker
    int sumaAux = 0; // variable local para acumular la suma de los numeros que procesa cada Worker
    for i = ini..fin{
        sumaAux += vector[i]; // acumulo la suma de los numeros que procesa cada Worker
    }
    P(mutex);
    suma += sumaAux; // actualizo la variable global suma con la suma acumulada por cada Worker
    V(mutex);
    P(barrera);
    cant++;
    if (cant == 10)
        for i = 0..9
            V(espero); // liberar a todos los Workers
    V(barrera);
    P(espero); // esperar a que todos los Workers terminen
    write("Promedio: ", suma / 1000000); // imprimir el resultado 
}

// Resolver con SEMÁFOROS la siguiente situación. A una acopiadora de cereales llegan 20 camiones que deben descargar su cereal. 
// Los camiones se descargan de a uno por vez, y de acuerdo con orden de llegada. Una vez que el camión llegó, espera a que llegue su turno para comenzar 
// a descargar su cereal. Nota: sólo se pueden usar procesos que representen a los camiones; cada camión descarga sólo una vez; la descarga del camión se simula por medio 
// de la funcion DESCARGAR() llamada por el camión.

sem mutex = 1; // semáforo para proteger la cola
sem espera[20] = ([20], 0); // array de semáforos para que cada camión espere su turno
bool libre = true;
queue cola; // cola para manejar el orden de llegada

Process Camion [id: 0..19]{
    P(mutex);
    if (libre){
        libre = false;
        V(mutex);
    } else {
        cola.push(id);
        V(mutex);
        P(espera[id]);
    }
    // una vez llegados a este punto es porque entro al if y pudo entrar a descargar, o porque entro al else y lo despertaron de su espera, lo que significa que es su turno para descargar
    DESCARGAR(); // simula que el camión está descargando su cereal
    P(mutex);
    if (cola.isEmpty()) libre = true; // si no hay camiones esperando, la playa queda libre
    else {
        int idAux = cola.pop(); // obtengo el id del siguiente camión que va a descargar
        V(espera[idAux]); // aviso al siguiente camión que ya puede descargar
    }
    V(mutex);
}

// Resolver con MONITORES el siguiente problema. En una cátedra hay un profesor, un auxiliar y 100 alumnos. Cada alumno continuamente hace consultas que pueden ser de 
// dos tipos: TEÓRICAS o PRÁCTICAS, cada vez que tiene una consulta para hacer se la envía por mail al docente correspondiente, y espera a que este le envíe la respuesta. 
// El profesor solo atiende consultas TEÓRICAS, y el auxiliar solo consultas PRÁCTICAS, cada uno resuelve sus consultas de acuerdo con orden de llegada. 
// Nota: maximizar concurrencia; el alumno sabe de qué tipo es cada consulta; los procesos NO deben terminar.

Process Alumno [id: 0..99]{
    text consulta; // cada alumno tiene una consulta para hacer
    while (true){
        bool esTeorica; // el alumno sabe si su consulta es teórica o práctica
        if (esTeorica) AdminConsulta[0].hacerConsulta(id, consulta, resp); // el alumno envía su consulta al profesor
        else AdminConsulta[1].hacerConsulta(id, consulta, resp); // el alumno envía su consulta al auxiliar
    }
}

Process Docente [id: 0..1] { // id 0 para el profesor, id 1 para el auxiliar
    text cons, respuesta; // cada docente tiene una respuesta para enviar a los alumnos
    while (true){
        int idAlumno; // para saber qué alumno hizo la consulta
        AdminConsulta[id].atenderConsulta(idAlumno, cons); // el docente atiende la consulta del alumno, se atienden de acuerdo con orden de llegada
        respuesta = ResponderConsulta(cons); // el docente responde la consulta del alumno, se simula con la función ResponderConsulta()
        AdminConsulta[id].enviarRespuesta(idAlumno, respuesta); // el docente le envía la respuesta al alumno
    }
}

Monitor AdminConsulta[id: 0..1] { // id 0 para el profesor, id 1 para el auxiliar
    cond hayPedido; // para que el alumno espere a que le llegue su turno para hacer la consulta y para que el docente sepa que hay una consulta para atender
    text consultas[100]; // array para guardar las consultas de los alumnos, para que el docente pueda atenderlas de acuerdo con orden de llegada
    Cola cola; // cola para manejar el orden de llegada de las consultas
    cond esperaRespuesta[100]; // para que cada alumno espere a que le llegue su respuesta, se podria usar directamente una sola variable condicion pero es buena práctica si se va a escalar a por ej: 2 auxiliares accediendo a la cola y tratando de despertar a alumnos.

    Procedure hacerConsulta(in int: idAlumno, in text: consulta, out text: resp){
        cola.push(idAlumno, consulta); // encola al alumno que hizo la consulta
        signal(hayPedido); // aviso al docente que hay una consulta para atender
        wait(esperaRespuesta[idAlumno]); // el alumno espera a que le llegue su respuesta
        resp = consultas[idAlumno]; // una vez que el docente le envió la respuesta, el alumno la recibe
    }

    Procedure atenderConsulta(out int: idAlumno, out text: consulta){
        if (cola.isEmpty()) wait(hayPedido); // si no hay consultas para atender, el docente espera
        cola.pop(idAlumno, consulta); // desencola al alumno y obtiene su consulta
    }

    Procedure enviarRespuesta(in int: idAlumno, in text: respuesta){
        consultas[idAlumno] = respuesta; // guarda la respuesta para el alumno
        signal(esperaRespuesta[idAlumno]); // aviso al alumno que ya le envié la respuesta
    }

}


