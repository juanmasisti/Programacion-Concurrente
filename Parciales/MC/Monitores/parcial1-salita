// Resolver el siguiente problema con MONITORES. Simular la atencion en una Salita Médica para vacunar contra el coronavirus. 
// Hay una enfermera encargada de vacunar a 30 pacientes, cada paciente tiene un turno asignado (valor entero entre 1..30 ya
// conocido por el paciente). La enfermera atiende a los pacientes de acuerdo al turno que cada uno tiene asignado.
// Cada paciente al llegar espera a que sea su turno y se dirige al consultorio para que la enfermera lo vacune, y luego se retira.
// Nota: suponer que existe una funcion Vacunar() que simula la atencion del paciente por parte de la enfermera. 
// Todos los procesos deben terminar
// Para que quede mas clara la explicacion supondremos que los turnos son de 0..29.

Process paciente [p: 0..29] {
    int turno = p; // cada paciente conoce su turno
    Salita.esperar(); // espera hasta que sea su turno
    Consultorio.esperarAtencion(turno); // demora hasta que termine de ser atendido
}

Process enfermera{
    for i = 0..29{
        Salita.siguiente(); // despertar al paciente que tiene el turno actual, podria ser que la enfermera tenga que demorarse esperando a que llegue el paciente
        Consultorio.esperarPaciente(); // sincroniza que el paciente y la enfermera hayan llegado al consultorio
        Vacunar();
        Consultorio.terminarAtencion(); // avisa que se termino la atencion y espera a que el paciente se retire para seguir con el siguiente turno
    }
}

Monitor Salita { // impone orden estricto por turno y maneja ambos casos (paciente temprano / enfermera esperando).
    int turnoActual = -1; // variable para manejar el turno actual
    cond espera[30]; // cola de espera para los pacientes
    cond enf; // para demorar a la enfermera si el paciente no llegó, y para que el paciente avise a la enfermera que ya llegó
    bool presente[30] = ([30] false); // para saber si el paciente está presente

    Procedure esperar(int turno){
        presente[turno] = true; // marco que el paciente está presente
        if (turnoActual == turno){ 
            signal(enf); // si es mi turno, aviso a la enfermera
        }
        wait(espera[turno]); // espero a que sea mi turno
    }

    Procedure siguiente(){
        turnoActual++;
        if (not presente[turnoActual]){ 
            wait(enf); // si el paciente no está presente, la enfermera espera
        }
        signal(espera[turnoActual]); // despierto al paciente cuyo turno es el actual
    }
}

Monitor Consultorio { // realiza el handshake (intercambio / sincronización) entre paciente y enfermera: paciente avisa que llegó, enfermera lo atiende y ambos se sincronizan para que la vacunación ocurra en el momento correcto y el paciente no se vaya antes.
    cond enf, pac; // colas de espera para la enfermera y el paciente
    bool llegoPaciente = false; // para que la enfermera sepa si el paciente llegó

    Procedure esperarAtencion(turno: in int){
        llegoPaciente = true; // marco que el paciente llegó
        signal(enf); // aviso a la enfermera que ya estoy en el consultorio
        wait(pac); // espero a que la enfermera me atienda
        signal(enf); // aviso a la enfermera que ya terminé de ser atendido y me retiré
    }

   Procedure esperarPaciente(){
        if (!llegoPaciente){ // si el paciente no llegó, la enfermera espera
            wait(enf);
        }
        llegoPaciente = false; // marco que el paciente ya está siendo atendido
    }

    Procedure terminarAtencion(){
        signal(pac); // aviso al paciente que ya terminé de atenderlo
        wait(enf); // espero a que el paciente se retire
    }
}
